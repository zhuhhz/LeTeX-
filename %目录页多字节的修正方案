%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%目录页多字节的修正方案
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% 主目录只显示节
\setbeamertemplate{subsection in toc}[hide]
% 子节计数器，用于判断第一个子节
\newcounter{subsecinsec}
% 在每节开始时显示概览页
\AtBeginSection{
  % 关键：在显示目录前先设置当前子节
  \begingroup
  %\makeatletter
  \setcounter{subsection}{0}
  \setcounter{subsecinsec}{0}
  %\def\beamer@subsection@last@before@skip{0pt}%
  %\def\beamer@subsection@last@after@skip{0pt}%
  \setcounter{subsection}{0}%
  %\makeatother
  
  \begin{frame}{\insertsectionhead~目录}
    \tableofcontents[sections={\thesection}]
  \end{frame}
  
  \endgroup
}

% 在每个子节前显示过渡页（除了第一个）
\newcounter{subsecinsec}
\setcounter{subsecinsec}{0}

\AtBeginSubsection{
  \stepcounter{subsecinsec}
  \ifnum\value{subsecinsec}>0
    \begin{frame}{\insertsectionhead~目录}
      \tableofcontents[sections={\thesection}, currentsubsection]
    \end{frame}
  \fi
}

% 在每个节结束时重置子节计数器
\AtEndSection{
  \setcounter{subsecinsec}{0}
}
